{
  "name": "json-sanitizer",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "biome check",
    "check:fix": "biome check --fix",
    "format": "biome format",
    "format:write": "biome format --write",
    "yolo": "bun run check:fix && bun run format:write && bun run build",
    "preview": "bun run build && wrangler dev",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "wrangler": "^4.77.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "packageManager": "bun@1.3.10"
}
